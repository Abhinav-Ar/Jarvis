# Required: create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI models and voice
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
JARVIS_CUES=1
JARVIS_PROGRESS_SPEECH=1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
JARVIS_STREAM_TRANSCRIPTION=1
# Optional PortAudio device number/name when macOS chooses the wrong speakers.
JARVIS_OUTPUT_DEVICE=
OPENAI_TTS_MODEL=tts-1
OPENAI_VOICE=echo

# Listening behavior
JARVIS_HOTWORD=jarvis
JARVIS_LANGUAGE=en
JARVIS_ENERGY_THRESHOLD=250
JARVIS_SILENCE_SECONDS=1.4
JARVIS_MAX_PHRASE_SECONDS=30
JARVIS_UNITS=fahrenheit
# JARVIS_INPUT_DEVICE=1
# JARVIS_MUTE=0
JARVIS_MAX_SPOKEN_CHARS=500
JARVIS_BARGE_IN_THRESHOLD=450
JARVIS_BARGE_IN_THRESHOLD_RATIO=1.7
JARVIS_BARGE_IN_SECONDS=0.12
JARVIS_BARGE_IN_GRACE_SECONDS=0.5

# Optional Spotify integration. Create an app at developer.spotify.com and
# register this exact redirect URI in its settings.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional Todoist task creation. Generate this in Todoist Settings → Integrations.
TODOIST_API_TOKEN=

# Optional smart-home/device control through your Home Assistant server.
# Example URL: http://homeassistant.local:8123
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
