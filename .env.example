# Required: create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI models and voice
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
ORION_CUES=1
ORION_PROGRESS_SPEECH=1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
ORION_STREAM_TRANSCRIPTION=1
ORION_LOCAL_TRANSCRIPTION=1
ORION_LOCAL_TRANSCRIBE_MODEL=mlx-community/whisper-tiny
ORION_ALLOW_TRANSCRIPTION_FALLBACK=1
# Optional PortAudio device number/name when macOS chooses the wrong speakers.
ORION_OUTPUT_DEVICE=
OPENAI_TTS_MODEL=tts-1
OPENAI_VOICE=echo
# Free on-device speech. Set to 0 only when intentionally using paid cloud TTS.
ORION_LOCAL_SPEECH=1
ORION_MACOS_VOICE=

# Hard local cost controls. Known commands do not consume these calls.
ORION_CLOUD_ENABLED=1
ORION_MAX_CLOUD_CALLS_PER_DAY=100
# Active-session continuity. Tool-completed turns and the current native project
# are retained locally so follow-ups such as "change that" route correctly.
ORION_SESSION_CONTEXT_TURNS=12
ORION_SESSION_USER_CHARS=1800
ORION_SESSION_ASSISTANT_CHARS=2600
# Colon-separated folders Jarvis is explicitly allowed to index locally.
ORION_INDEX_ROOTS=
ORION_INDEX_MAX_FILES=500

# Listening behavior
ORION_HOTWORD=orion
ORION_LANGUAGE=en
ORION_ENERGY_THRESHOLD=250
ORION_SILENCE_SECONDS=1.4
ORION_MAX_PHRASE_SECONDS=30
ORION_UNITS=fahrenheit
# ORION_INPUT_DEVICE=1
# ORION_MUTE=0
ORION_MAX_SPOKEN_CHARS=500
ORION_BARGE_IN_THRESHOLD=450
ORION_BARGE_IN_THRESHOLD_RATIO=1.7
ORION_BARGE_IN_SECONDS=0.12
ORION_BARGE_IN_GRACE_SECONDS=0.5
ORION_PUSH_TO_TALK=1

# Capability-family adapters. Leave blank until the service is authorized.
# Google OAuth refresh-token flow; requested scopes are Drive file, Sheets,
# Docs, and Slides. GOOGLE_ACCESS_TOKEN is also accepted for short-lived testing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# GOOGLE_ACCESS_TOKEN=

# Microsoft Graph adapter authorization (OneDrive/Excel/Word/PowerPoint/Outlook).
MICROSOFT_ACCESS_TOKEN=

# Optional override; ORION auto-detects the Codex binary bundled with ChatGPT.
ORION_CODEX_PATH=

# Optional Spotify integration. Create an app at developer.spotify.com and
# register this exact redirect URI in its settings.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional Todoist task creation. Generate this in Todoist Settings → Integrations.
TODOIST_API_TOKEN=

# Optional smart-home/device control through your Home Assistant server.
# Example URL: http://homeassistant.local:8123
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
