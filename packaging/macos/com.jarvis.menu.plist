<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jarvis.menu</string>
    <key>ProgramArguments</key>
    <array>
        <string>__MENU_APP__/Contents/MacOS/JarvisMenu</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/.runtime/menu.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/.runtime/menu-error.log</string>
</dict>
</plist>
